# ============================================
# AAPLE SHASAN — ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in real values
# ============================================

# App
NODE_ENV=production
APP_NAME=AapleShasan
APP_URL=https://aapleshasan.maharashtra.gov.in
FRONTEND_URL=https://aapleshasan.maharashtra.gov.in
PORT=5000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aapleshasan
POSTGRES_USER=aapleshasan_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_64_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Session
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_CHARS

# OTP / SMS (Twilio or MSG91)
SMS_PROVIDER=msg91
MSG91_API_KEY=YOUR_MSG91_API_KEY
MSG91_SENDER_ID=AAPLESH
OTP_EXPIRY_MINUTES=10

# Email (AWS SES or SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mahadbt.gov.in
SMTP_PORT=587
SMTP_USER=noreply@aapleshasan.maharashtra.gov.in
SMTP_PASS=CHANGE_ME_EMAIL_PASSWORD
EMAIL_FROM=Aaple Shasan <noreply@aapleshasan.maharashtra.gov.in>

# Aadhaar Mock (in prod: integrate UIDAI Sandbox)
AADHAAR_API_URL=https://sandbox.uidai.gov.in
AADHAAR_API_KEY=YOUR_UIDAI_SANDBOX_KEY

# AI / NLP Engine
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
AI_MODEL=claude-sonnet-4-6

# File Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Encryption
FIELD_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# DBT Webhook (Maharashtra PFMS)
DBT_WEBHOOK_URL=https://pfms.nic.in/webhook/disbursement
DBT_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CORS
ALLOWED_ORIGINS=https://aapleshasan.maharashtra.gov.in,https://admin.aapleshasan.maharashtra.gov.in
